generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}



enum Gender {
  Male
  Female
  Transgender
}

enum Type {
  Unlisted
  Public
  Private
}

model Users {
  id String @id @default(uuid())
  email String @unique
  password String
  firstName String
  lastName String
  gender Gender
  dateOfBirth DateTime
  channel Boolean? @default(false)
  channelName String?
  bannerUrl String?
  profilePicture String?
  description String?
  subscriberCount Int @default(0)
  uploads Uploads[]
}

model Uploads {
  uploadId String @id @default(uuid())
  vedioUrl String
  thumbnailUrl String
  description String
  title String
  type Type
  likeCount Int @default(0)
  views Int @default(0)
  deleted Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId String
  userid Users @relation(fields: [userId],references: [id])
}